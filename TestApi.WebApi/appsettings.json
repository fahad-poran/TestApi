{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "Jwt": {
    "Key": "ThisIsASuperSecretKeyForJwtToken12345678901234567890",
    "Issuer": "TestApi",
    "Audience": "TestApiUsers",
    "ExpiryInMinutes": 60
  },
    "ConnectionStrings": {
        "DefaultConnection": "Server=host.docker.internal,1433;Database=TestApiDb;User Id=sa;Password=Hello@123;TrustServerCertificate=True;"
    },
  "AllowedHosts": "*"
}
